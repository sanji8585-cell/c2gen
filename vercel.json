{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "vite --port $PORT",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "crons": [
    { "path": "/api/scheduler-trigger", "schedule": "0 * * * *" },
    { "path": "/api/analytics", "schedule": "0 */6 * * *" }
  ],
  "functions": {
    "api/gemini.ts": { "maxDuration": 60 },
    "api/elevenlabs.ts": { "maxDuration": 60 },
    "api/fal.ts": { "maxDuration": 120 },
    "api/fal-poll.ts": { "maxDuration": 30 },
    "api/openai.ts": { "maxDuration": 60 },
    "api/auth.ts": { "maxDuration": 60 },
    "api/gamification.ts": { "maxDuration": 60 },
    "api/payments.ts": { "maxDuration": 30 },
    "api/projects.ts": { "maxDuration": 30 },
    "api/playground.ts": { "maxDuration": 10 },
    "api/user.ts": { "maxDuration": 30 },
    "api/scheduler-trigger.ts": { "maxDuration": 60 },
    "api/campaign.ts": { "maxDuration": 30 },
    "api/approval.ts": { "maxDuration": 30 },
    "api/brand-preset.ts": { "maxDuration": 60 },
    "api/channel.ts": { "maxDuration": 30 },
    "api/character.ts": { "maxDuration": 120 },
    "api/youtube-auth.ts": { "maxDuration": 30 },
    "api/youtube-upload.ts": { "maxDuration": 120 },
    "api/tiktok-auth.ts": { "maxDuration": 30 },
    "api/tiktok-upload.ts": { "maxDuration": 120 },
    "api/analytics.ts": { "maxDuration": 60 },
    "api/pilot/save-content.ts": { "maxDuration": 120 }
  }
}
