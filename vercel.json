{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/gemini.ts": { "maxDuration": 60 },
    "api/elevenlabs.ts": { "maxDuration": 30 },
    "api/fal.ts": { "maxDuration": 30 },
    "api/fal-poll.ts": { "maxDuration": 10 },
    "api/auth.ts": { "maxDuration": 10 }
  }
}
